# 
# Synthesis run script generated by Vivado
# 

set_msg_config -id {HDL 9-1061} -limit 100000
set_msg_config -id {HDL 9-1654} -limit 100000
create_project -in_memory -part xc7a35ticsg324-1L

set_param project.singleFileAddWarning.threshold 0
set_param project.compositeFile.enableAutoGeneration 0
set_param synth.vivado.isSynthRun true
set_property webtalk.parent_dir D:/hdl_testbench_sample/project_1/project_1.cache/wt [current_project]
set_property parent.project_path D:/hdl_testbench_sample/project_1/project_1.xpr [current_project]
set_property default_lib xil_defaultlib [current_project]
set_property target_language Verilog [current_project]
read_verilog -library xil_defaultlib D:/hdl_testbench_sample/sample_circuit.v
foreach dcp [get_files -quiet -all *.dcp] {
  set_property used_in_implementation false $dcp
}

synth_design -top sample_circuit -part xc7a35ticsg324-1L


write_checkpoint -force -noxdef sample_circuit.dcp

catch { report_utilization -file sample_circuit_utilization_synth.rpt -pb sample_circuit_utilization_synth.pb }
